<label class="theme-switch" for="theme-toggle">
    <input id="theme-toggle"
           type="checkbox"
           role="switch"
           aria-label="Cambiar tema claro/oscuro"/>
    <span id="theme-status-icon" class="theme-status-icon" aria-hidden="true"></span>
</label>
<span id="theme-status" class="visually-hidden">
    Tema claro activado
</span>