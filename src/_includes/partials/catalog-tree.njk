{%- macro renderTree(nodes, level = 0, parentPath = "") -%}
<ul class="catalog-tree{% if level > 0 %} catalog-tree--nested{% endif %}">
  {%- for node in nodes %}
    {%- set nodeLabel = node.index.data.title or node.label -%}
    {%- set nodePath = (parentPath and (parentPath ~ "/" ~ nodeLabel)) or nodeLabel -%}
    <li class="catalog-node catalog-node--{{ node.level }}">
      <details
        class="catalog-details"
        data-catalog-node
        data-catalog-level="{{ node.level }}"
        data-catalog-path="{{ nodePath | escape }}"
      >
        <summary class="catalog-summary">
          <span class="catalog-label">
            {{ nodeLabel }}
          </span>
          <span class="catalog-count" aria-label="{{ node.totalPosts }} publicaciones">{{ node.totalPosts }}</span>
        </summary>
        <div>
          {%- if node.posts.length -%}
            <ul class="catalog-posts">
              {%- for post in node.posts -%}
                <li>
                  <a href="{{ post.url | url }}">{{ post.data.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if node.children.length -%}
            {{ renderTree(node.children, level + 1, nodePath) }}
          {%- endif -%}
        </div>
      </details>
    </li>
  {%- endfor %}
</ul>
{%- endmacro -%}
