{%- macro renderTree(nodes) -%}
<ul class="list-group list-group-flush">
  {%- for node in nodes %}
    <li class="list-group-item border-0 px-0">
      <details open class="mb-2">
        <summary class="d-flex justify-content-between align-items-center gap-2 py-1">
          <span class="fw-semibold">
            {{ node.index.data.title or node.label }}
          </span>
          <span class="badge text-bg-secondary rounded-pill">{{ node.totalPosts }}</span>
        </summary>
        <div class="ms-3 mt-2">
          {%- if node.posts.length -%}
            <ul class="list-group list-group-flush mb-2">
              {%- for post in node.posts -%}
                <li class="list-group-item py-1 px-0 border-0">
                  <a href="{{ post.url | url }}" class="link-body-emphasis link-underline-opacity-25 link-underline-opacity-75-hover">{{ post.data.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if node.children.length -%}
            {{ renderTree(node.children) }}
          {%- endif -%}
        </div>
      </details>
    </li>
  {%- endfor %}
</ul>
{%- endmacro -%}
